<!DOCTYPE html>
<html lang="en" class="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google" content="notranslate" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BeenThere.Web.styles.css"]" />
    <!-- Leaflet map library (ADR-0007, managed via package.json) -->
    <link rel="stylesheet" href="/lib/leaflet/leaflet.css" />
    <script src="/lib/leaflet/leaflet.js"></script>
    <!-- Leaflet marker cluster plugin -->
    <link rel="stylesheet" href="/lib/leaflet.markercluster/MarkerCluster.css" />
    <link rel="stylesheet" href="/lib/leaflet.markercluster/MarkerCluster.Default.css" />
    <script src="/lib/leaflet.markercluster/leaflet.markercluster.js"></script>
    <!-- Leaflet heat plugin -->
    <script src="/lib/leaflet.heat/leaflet-heat.js"></script>
    <!-- Tailwind CSS (built via npm/PostCSS, see package.json) -->
    <link rel="stylesheet" href="/css/tailwind.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body class="bg-surface text-slate-100 font-sans antialiased">
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>


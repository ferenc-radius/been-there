@page "/"

@using BeenThere.Web.Components
@using BeenThere.Core.Interfaces
@using BeenThere.Infrastructure.Persistence
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Db
@inject ICurrentUserService CurrentUserService

<PageTitle>BeenThere — Map</PageTitle>

<div class="flex h-full">

    <aside class="flex flex-col w-80 shrink-0 border-r border-surface-border bg-surface-raised overflow-hidden">

        <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-border">
            <Icon Name="search" Size="16" Class="text-slate-500" />
            <input type="search"
                   placeholder="Search routes…"
                   class="flex-1 bg-transparent text-sm text-slate-200 placeholder:text-slate-500 outline-none" />
            <button class="text-slate-500 hover:text-slate-300 transition-colors" title="Filter">
                <Icon Name="filter" Size="16" />
            </button>
        </div>

        <div class="flex-1 overflow-y-auto">
            @if (Routes == null)
            {
                <div class="flex items-center justify-center h-32 text-slate-600">
                    <p class="text-sm">Loading…</p>
                </div>
            }
            else if (Routes.Count == 0)
            {
                <div class="flex flex-col items-center justify-center h-32 text-slate-600">
                    <p class="text-sm">No routes yet — import a GPX to get started.</p>
                </div>
            }
            else
            {
                <div class="divide-y divide-surface-border">
                    @foreach (var route in Routes)
                    {
                        <div class="px-4 py-3 hover:bg-surface-overlay cursor-pointer transition-colors">
                            <p class="text-sm font-medium text-slate-200">@route.Name</p>
                            <p class="text-xs text-slate-500 mt-1">@((route.DistanceM / 1000d).ToString("F1")) km</p>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="px-4 py-3 border-t border-surface-border">
            <p class="text-xs text-slate-500">@(Routes?.Count ?? 0) routes · @((TotalDistanceM / 1000d).ToString("F0")) km total</p>
        </div>

    </aside>

    <div class="flex-1 relative bg-surface-overlay">
        <MapComponent />
    </div>

</div>

@code {
    private List<BeenThere.Core.Domain.Route>? Routes;
    private double TotalDistanceM;

    protected override async Task OnInitializedAsync()
    {
        var userId = CurrentUserService.UserId;
        if (string.IsNullOrEmpty(userId)) return;

        Routes = await Db.Routes
            .AsNoTracking()
            .Where(r => r.UserId == userId)
            .OrderByDescending(r => r.Date)
            .ToListAsync();

        TotalDistanceM = Routes?.Sum(r => r.DistanceM) ?? 0;
    }
}

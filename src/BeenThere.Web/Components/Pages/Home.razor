@page "/"

@using BeenThere.Web.Components
@using BeenThere.Core.Interfaces
@using BeenThere.Core.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop

<PageTitle>BeenThere — Map</PageTitle>

<div class="flex h-full">

    <aside class="flex flex-col w-80 shrink-0 border-r border-surface-border bg-surface-raised overflow-hidden">

        <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-border">
            <Icon Name="search" Size="16" Class="text-slate-500" />
            <input type="search"
                   @bind="searchQuery"
                   @bind:event="oninput"
                   placeholder="Search routes…"
                   class="flex-1 bg-transparent text-sm text-slate-200 placeholder:text-slate-500 outline-none" />
            <button @onclick="() => isFiltersPanelOpen = !isFiltersPanelOpen"
                    class="relative text-slate-500 hover:text-slate-300 transition-colors" 
                    title="Filter">
                <Icon Name="filter" Size="16" />
                @if (GetActiveFilterCount() > 0)
                {
                    <span class="absolute top-0 right-0 inline-flex items-center justify-center w-3 h-3 rounded-full bg-brand text-[10px] font-bold text-white leading-none">
                        @GetActiveFilterCount()
                    </span>
                }
            </button>
        </div>

        <div class="flex-1 overflow-y-auto">
            @if (Routes == null)
            {
                <div class="flex items-center justify-center h-32 text-slate-600">
                    <p class="text-sm">Loading…</p>
                </div>
            }
            else if (Routes.Count == 0)
            {
                <div class="flex flex-col items-center justify-center h-32 text-slate-600">
                    <p class="text-sm">No routes yet — import a GPX to get started.</p>
                </div>
            }
            else
            {
                <div class="divide-y divide-surface-border">
                    @foreach (var route in Routes)
                    {
                        <div class="px-4 py-3 hover:bg-surface-overlay transition-colors group @(SelectedRouteId == route.Id ? "bg-surface-overlay border-l-2 border-brand" : "")" 
                             @onclick="() => SelectRoute(route.Id)">
                            <div class="flex items-start justify-between">
                                <div class="flex-1 cursor-pointer">
                                    <p class="text-sm font-medium text-slate-200">@route.Name</p>
                                    <p class="text-xs text-slate-500 mt-1">@((route.DistanceM / 1000d).ToString("F1")) km</p>
                                </div>
                                <button @onclick:stopPropagation="true"
                                        @onclick="() => DeleteRouteWithConfirmation(route.Id, route.Name)"
                                        class="opacity-0 group-hover:opacity-100 transition-opacity p-1 hover:text-red-400 text-slate-500"
                                        title="Delete route">
                                    <Icon Name="trash" Size="16" />
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="px-4 py-3 border-t border-surface-border">
            <p class="text-xs text-slate-500">@(Routes?.Count ?? 0) routes · @((TotalDistanceM / 1000d).ToString("F0")) km total</p>
        </div>

    </aside>

    <!-- Filter Modal Component -->
    <FilterModal IsOpen="isFiltersPanelOpen"
                 OnOpenChanged="EventCallback.Factory.Create(this, (bool isOpen) => { isFiltersPanelOpen = isOpen; })"
                 @bind-PlaceQuery="placeQuery"
                 SuggestedPlaces="suggestedPlaces"
                 SelectedPlace="selectedPlace"
                 @bind-SelectedRadiusKm="selectedRadiusKm"
                 IsSearchingPlaces="isSearchingPlaces"
                 @bind-FilterTag="filterTag"
                 @bind-FilterMinKm="filterMinKm"
                 @bind-FilterMaxKm="filterMaxKm"
                 IsApplying="isApplyingFilters"
                 OnSearchPlaces="SearchPlaces"
                 OnSelectPlace="EventCallback.Factory.Create(this, (GeocodeResult p) => SelectPlace(p))"
                 OnClearPlace="EventCallback.Factory.Create(this, () => ClearPlace())"
                 OnClearFilters="EventCallback.Factory.Create(this, () => ClearFilters())"
                 OnApply="EventCallback.Factory.Create(this, () => ApplyFiltersAndClose())" />

    <div class="flex-1 relative bg-surface-overlay">
        <MapComponent SelectedRouteId="SelectedRouteId" />
    </div>

</div>

@code {
    [Inject]
    private IRouteService RouteService { get; set; } = default!;

    [Inject]
    private ICurrentUserService CurrentUserService { get; set; } = default!;

    [Inject]
    private IGeocodingService GeocodingService { get; set; } = default!;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    private List<RouteSearchResult>? Routes;
    private double TotalDistanceM;
    private Guid? SelectedRouteId;

    // Search
    private string searchQuery = string.Empty;

    // Filter panel state
    private bool isFiltersPanelOpen;
    private bool isApplyingFilters;

    // Place-based search state
    private string placeQuery = string.Empty;
    private List<GeocodeResult>? suggestedPlaces;
    private GeocodeResult? selectedPlace;
    private int selectedRadiusKm = 10;
    private bool isSearchingPlaces;
    private CancellationTokenSource? placeSearchCts;

    // Other filters
    private string? filterTag;
    private string? filterMinKm;
    private string? filterMaxKm;

    protected override async Task OnInitializedAsync()
    {
        var userId = CurrentUserService.UserId;
        if (string.IsNullOrEmpty(userId)) return;

        Routes = (await RouteService.SearchRoutesAsync(userId, new RouteSearchFilter())).ToList();
        TotalDistanceM = Routes?.Sum(r => r.DistanceM) ?? 0;
    }

    private void SelectRoute(Guid routeId)
    {
        SelectedRouteId = SelectedRouteId == routeId ? null : routeId;
    }

    private async Task DeleteRouteWithConfirmation(Guid routeId, string routeName)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete '{routeName}'?"))
            return;

        var userId = CurrentUserService.UserId;
        if (string.IsNullOrEmpty(userId)) return;

        var deleted = await RouteService.DeleteRouteAsync(userId, routeId);
        if (deleted)
        {
            Routes?.RemoveAll(r => r.Id == routeId);
            TotalDistanceM = Routes?.Sum(r => r.DistanceM) ?? 0;
            if (SelectedRouteId == routeId) SelectedRouteId = null;
            StateHasChanged();
        }
    }

    private int GetActiveFilterCount()
    {
        int count = 0;
        if (selectedPlace != null) count++;
        if (selectedRadiusKm != 10) count++;
        if (!string.IsNullOrEmpty(filterTag)) count++;
        if (!string.IsNullOrEmpty(filterMinKm) && filterMinKm != "0") count++;
        if (!string.IsNullOrEmpty(filterMaxKm) && filterMaxKm != "∞") count++;
        return count;
    }

    private async Task SearchPlaces(ChangeEventArgs e)
    {
        placeQuery = e.Value?.ToString() ?? string.Empty;
        suggestedPlaces = null;

        placeSearchCts?.Dispose();
        placeSearchCts = new();

        if (placeQuery.Length < 3)
        {
            suggestedPlaces = null;
            isSearchingPlaces = false;
            return;
        }

        isSearchingPlaces = true;
        try
        {
            await Task.Delay(300, placeSearchCts.Token);
            if (placeSearchCts.Token.IsCancellationRequested) return;

            var results = await GeocodingService.GeocodeAsync(placeQuery, maxResults: 7, ct: placeSearchCts.Token);
            suggestedPlaces = results.ToList();
        }
        catch (OperationCanceledException) { }
        catch { suggestedPlaces = null; }
        finally
        {
            isSearchingPlaces = false;
        }
    }

    private void SelectPlace(GeocodeResult place)
    {
        selectedPlace = place;
        placeQuery = place.DisplayName ?? string.Empty;
        suggestedPlaces = null;
    }

    private void ClearPlace()
    {
        selectedPlace = null;
        placeQuery = string.Empty;
        suggestedPlaces = null;
    }

    private async Task ApplyFilters()
    {
        if (isApplyingFilters) return;
        isApplyingFilters = true;

        try
        {
            var userId = CurrentUserService.UserId;
            if (string.IsNullOrEmpty(userId)) return;

            double? minLength = double.TryParse(filterMinKm, out var minKm) ? minKm * 1000.0 : null;
            double? maxLength = double.TryParse(filterMaxKm, out var maxKm) ? maxKm * 1000.0 : null;

            var filter = new RouteSearchFilter(
                PlaceName: selectedPlace?.DisplayName,
                RadiusKm: selectedRadiusKm,
                MinLengthM: minLength,
                MaxLengthM: maxLength,
                Tag: string.IsNullOrWhiteSpace(filterTag) ? null : filterTag);

            var results = await RouteService.SearchRoutesAsync(userId, filter);
            Routes = results.ToList();
            TotalDistanceM = Routes.Sum(r => r.DistanceM);
        }
        finally
        {
            isApplyingFilters = false;
        }
    }

    private async Task ApplyFiltersAndClose()
    {
        await ApplyFilters();
        isFiltersPanelOpen = false;
    }

    private async Task ClearFilters()
    {
        filterTag = filterMinKm = filterMaxKm = null;
        selectedPlace = null;
        placeQuery = string.Empty;
        suggestedPlaces = null;
        selectedRadiusKm = 10;
        var userId = CurrentUserService.UserId;
        if (string.IsNullOrEmpty(userId)) return;
        Routes = (await RouteService.SearchRoutesAsync(userId, new RouteSearchFilter())).ToList();
        TotalDistanceM = Routes.Sum(r => r.DistanceM);
    }
}

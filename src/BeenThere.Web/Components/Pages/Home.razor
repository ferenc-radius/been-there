@page "/"

<PageTitle>BeenThere — Map</PageTitle>

<div class="flex h-full">

    <aside class="flex flex-col w-80 shrink-0 border-r border-surface-border bg-surface-raised overflow-hidden">

        <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-border">
            <Icon Name="search" Size="16" Class="text-slate-500" />
            <input type="search"
                   placeholder="Search routes…"
                   class="flex-1 bg-transparent text-sm text-slate-200 placeholder:text-slate-500 outline-none" />
            <button class="text-slate-500 hover:text-slate-300 transition-colors" title="Filter">
                <Icon Name="filter" Size="16" />
            </button>
        </div>

        <div class="flex-1 overflow-y-auto">
            <div class="flex flex-col items-center justify-center h-32 text-slate-600">
                <p class="text-sm">No routes yet — import a GPX to get started.</p>
            </div>
        </div>

        <div class="px-4 py-3 border-t border-surface-border">
            <p class="text-xs text-slate-500">0 routes · 0 km total</p>
        </div>

    </aside>

    <div class="flex-1 relative bg-surface-overlay">
        <div class="absolute inset-0 flex items-center justify-center text-slate-600">
            <div class="text-center space-y-3">
                <Icon Name="map" Size="48" Class="mx-auto opacity-30" />
                <p class="text-sm">Leaflet map coming in Milestone 4</p>
            </div>
        </div>
    </div>

</div>

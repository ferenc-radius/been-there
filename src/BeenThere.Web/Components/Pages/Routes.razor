@page "/routes"

<PageTitle>BeenThere — Routes</PageTitle>

<div class="max-w-3xl mx-auto px-6 py-10 space-y-6">

    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-xl font-semibold text-slate-100">Routes</h1>
            <p class="text-sm text-slate-400 mt-1">Your full route library with filters.</p>
        </div>
        <a href="/import"
           class="flex items-center gap-2 rounded-lg bg-brand/90 hover:bg-brand px-4 py-2 text-sm font-medium text-white transition-colors">
            <Icon Name="upload" Size="16" />
            Import
        </a>
    </div>

    <div class="rounded-2xl border border-surface-border bg-surface-raised px-6 py-16 text-center text-slate-600">
        <Icon Name="route" Size="40" Class="mx-auto opacity-30 mb-3" />
        <p class="text-sm">Route library coming in Milestone 3</p>
    </div>

</div>

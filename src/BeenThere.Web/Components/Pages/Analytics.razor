@page "/analytics"

@using BeenThere.Core.Interfaces
@using BeenThere.Core.Models
@inject IRouteService RouteService
@inject ICurrentUserService CurrentUserService

<PageTitle>BeenThere — Analytics</PageTitle>

<div class="max-w-4xl mx-auto px-6 py-10 space-y-6">
    <h1 class="text-2xl font-bold text-slate-100">Analytics</h1>

    @if (analytics == null)
    {
        <p class="text-slate-500">Loading…</p>
    }
    else
    {
        <div class="grid grid-cols-2 gap-4">
            <div class="rounded-lg border border-surface-border bg-surface-raised p-4">
                <p class="text-sm text-slate-400">Total distance</p>
                <p class="text-2xl font-bold text-slate-100">@analytics.TotalDistanceKm.ToString("F1") km</p>
            </div>
            <div class="rounded-lg border border-surface-border bg-surface-raised p-4">
                <p class="text-sm text-slate-400">Total routes</p>
                <p class="text-2xl font-bold text-slate-100">@analytics.TotalRoutes</p>
            </div>
        </div>

        <div class="rounded-lg border border-surface-border bg-surface-raised p-4">
            <p class="text-sm text-slate-400 mb-4">Km per year</p>
            <div class="flex items-end gap-2">
                @foreach (var (year, km) in analytics.DistanceByYear)
                {
                    var barHeight = MaxYearKm > 0 ? (int)(km / MaxYearKm * 160) : 0;
                    <div class="flex flex-col items-center">
                        <div class="bg-brand" style="width:24px;height:@(barHeight)px"></div>
                        <div class="text-xs text-slate-400 mt-1">@year</div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private RouteAnalytics? analytics;

    private double MaxYearKm => analytics?.DistanceByYear.Values.DefaultIfEmpty(1).Max() ?? 1;

    protected override async Task OnInitializedAsync()
    {
        var userId = CurrentUserService.UserId;
        if (string.IsNullOrEmpty(userId)) return;

        analytics = await RouteService.GetAnalyticsAsync(userId);
    }
}

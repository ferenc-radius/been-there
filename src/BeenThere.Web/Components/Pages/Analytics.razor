@page "/analytics"

<PageTitle>BeenThere — Analytics</PageTitle>

<div class="max-w-3xl mx-auto px-6 py-10 space-y-6">

    <div>
        <h1 class="text-xl font-semibold text-slate-100">Analytics</h1>
        <p class="text-sm text-slate-400 mt-1">Total km, km/year, most-repeated routes.</p>
    </div>

    @* Stat card grid placeholder *@
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        @foreach (var (label, icon) in new[] { ("Total km", "activity"), ("This year", "bar-chart"), ("Routes", "route") })
        {
            <div class="rounded-2xl border border-surface-border bg-surface-raised px-5 py-5">
                <div class="flex items-center gap-2 text-slate-500 text-xs font-medium mb-2">
                    <Icon Name="@icon" Size="14" />
                    @label
                </div>
                <p class="text-2xl font-bold text-slate-100">—</p>
            </div>
        }
    </div>

    <div class="rounded-2xl border border-surface-border bg-surface-raised px-6 py-16 text-center text-slate-600">
        <Icon Name="bar-chart" Size="40" Class="mx-auto opacity-30 mb-3" />
        <p class="text-sm">Analytics coming in Milestone 4</p>
    </div>

</div>

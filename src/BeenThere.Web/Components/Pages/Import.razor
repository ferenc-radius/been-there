@page "/import"

<PageTitle>BeenThere — Import</PageTitle>

<div class="max-w-2xl mx-auto px-6 py-10 space-y-6">

    <div>
        <h1 class="text-xl font-semibold text-slate-100">Import Routes</h1>
        <p class="text-sm text-slate-400 mt-1">Drag &amp; drop GPX or KML files to add them to your library.</p>
    </div>

    @* Drop zone *@
    <div class="flex flex-col items-center justify-center gap-4 rounded-2xl border-2 border-dashed border-surface-border bg-surface-raised/50 px-8 py-16 text-center hover:border-brand/60 hover:bg-brand/5 transition-colors cursor-pointer">
        <span class="flex size-14 items-center justify-center rounded-full bg-brand/10 text-brand">
            <Icon Name="upload" Size="28" />
        </span>
        <div>
            <p class="text-sm font-medium text-slate-200">Drop GPX / KML files here</p>
            <p class="text-xs text-slate-500 mt-1">or click to browse — coming in Milestone 3</p>
        </div>
    </div>

</div>
